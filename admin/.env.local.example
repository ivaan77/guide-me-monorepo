# Copy to .env.local and fill in.
API_URL=http://localhost:3001
ADMIN_API_TOKEN=<copy ADMIN_TOKEN from api/.env>

# To set a new password:
#   node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=<bcrypt hash>

# Auth.js / NextAuth
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=<random 64-char hex>
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3002

# Google Cloud Storage credentials for audio uploads. Base64-encode the
# service-account JSON before pasting:
#   base64 -i service-account.json | tr -d '\n'
GOOGLE_CLOUD_SERVICE_KEY=<base64-encoded service-account JSON>
GOOGLE_CLOUD_BUCKET=guide-me-app
