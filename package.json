{
  "name": "@guide-me-app/monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.16.0",
  "scripts": {
    "eas-build-pre-install": "corepack enable && corepack prepare yarn@4.16.0 --activate",
    "build:all": "tsc --build --verbose",
    "core:build": "yarn workspace @guide-me-app/core run build",
    "api:build": "yarn workspace @guide-me-app/api run build",
    "api:start:dev": "yarn workspace @guide-me-app/api run start",
    "web:build": "yarn workspace @guide-me-app/web run build",
    "web:start": "yarn workspace @guide-me-app/web run start",
    "web:start:dev": "yarn workspace @guide-me-app/web run dev",
    "admin:build": "yarn workspace @guide-me-app/admin run build",
    "admin:start": "yarn workspace @guide-me-app/admin run start",
    "admin:start:dev": "yarn workspace @guide-me-app/admin run dev",
    "mobile:start": "yarn workspace @guide-me-app/mobile run start"
  },
  "workspaces": [
    "web",
    "mobile",
    "api",
    "admin",
    "packages/*"
  ],
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/plugin-transform-runtime": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@types/node": "^20.14.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.1"
  },
  "resolutions": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
